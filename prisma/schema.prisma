generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameState {
  wait
  selecting
  playing
  ended
}

enum Stage {
  lobby
  roleSelection
  bet
  action
  settlement
  discussionVote
  review
}

enum Role {
  fatter1
  fatter2
  fatter
  passenger
}

enum ActionCard {
  listen
  blow
  grab
  endure
  suck
  scold
}

enum EnvironmentCard {
  gas
  stink
  stew
  none
}

model Room {
  roomId       String    @id @db.VarChar(64)
  roomCode     String    @unique @db.VarChar(6)
  ownerOpenId  String    @db.VarChar(64)
  gameState    GameState
  playerCount  Int
  roomConfig   Json
  currentRound Int       @default(0)
  currentStage Stage
  envDeck      Json
  version      Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  players Player[]
  rounds  Round[]
  matches Match[]
}

model Player {
  roomId         String      @db.VarChar(64)
  openId         String      @db.VarChar(64)
  nickname       String      @db.VarChar(64)
  avatar         String      @db.VarChar(256)
  seatNo         Int
  candidateRoles Json?
  selectedRole   Role?
  hp             Int         @default(4)
  votePower      Float       @default(1)
  isAlive        Boolean     @default(true)
  selectedAction ActionCard?
  passedBet      Boolean     @default(false)
  canSpeak       Boolean     @default(true)
  canVote        Boolean     @default(true)
  voteTarget     String?     @db.VarChar(64)
  isReady        Boolean     @default(false)
  joinTime       DateTime    @default(now())

  room Room @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@id([roomId, openId])
  @@index([roomId])
}

model Round {
  roomId           String           @db.VarChar(64)
  round            Int
  environmentCard  EnvironmentCard?
  betSubmissions   Json
  actionLogs       Json
  voteSubmissions  Json
  voteResult       Json
  settlementResult Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  room Room @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@id([roomId, round])
  @@index([roomId])
}

model Match {
  matchId      String   @id @db.VarChar(64)
  roomId       String   @db.VarChar(64)
  rounds       Json
  winnerResult Json
  createdAt    DateTime @default(now())

  room Room @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@index([roomId])
}

model User {
  openId    String   @id @db.VarChar(64)
  unionId   String?  @db.VarChar(64)
  nickname  String   @map("nickName") @db.VarChar(64)
  avatarUrl String?  @db.VarChar(256)
  gender    Int?
  city      String?  @db.VarChar(64)
  province  String?  @db.VarChar(64)
  country   String?  @db.VarChar(64)
  language  String?  @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wechat_users")
  @@index([unionId])
}
